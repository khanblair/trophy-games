{
  "mcpServers": {
    "github": {
      "command": "docker",
      "args": ["exec", "-i", "friendly_banzai", "github-mcp-server", "stdio"],
      "env": {},
      "disabled": false,
      "autoApprove": [
        "create_or_update_file",
        "push_files",
        "create_branch",
        "list_commits",
        "get_file_contents",
        "search_repositories"
      ]
    }
  }
}
